     "UserData": {
      "Fn::Base64": "#!/bin/bash\n#!/bin/bash\nset -e\nexec > /var/log/user-data.log 2>&1\n# --- System Setup ---\ndnf update -y\ndnf install -y git\ncurl -fsSL https://rpm.nodesource.com/setup_20.x | bash -\ndnf install -y nodejs\nnpm install -g pm2 typescript\n# --- Fetch Secrets from SSM ---\nGEMINI_API_KEY=$(aws ssm get-parameter --name \"/medhalabs/voice-agent/GEMINI_API_KEY\" --with-decryption --region ap-south-1 --query \"Parameter.Value\" --output text)\n# --- Clone Repository ---\ncd /home/ec2-user\ngit clone https://github.com/saicharangadamshetti/medhalabs-ai.git app || (cd app && git pull)\ncd /home/ec2-user/app/voice-agent\n# --- Write .env file ---\ncat > .env <<EOF\nNODE_ENV=production\nPORT=3001\nGEMINI_API_KEY=$GEMINI_API_KEY\nALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001,https://medha-labs-ai.site,https://medha-labs-ai.com,https://www.medha-labs-ai.com\nEOF\n# --- Install Dependencies & Build ---\nnpm install\nnpm run build\n# --- Start App with PM2 ---\npm2 start dist/index.js --name voice-agent --env production\npm2 save\n# --- Configure PM2 to start on reboot ---\nenv PATH=$PATH:/usr/bin pm2 startup systemd -u ec2-user --hp /home/ec2-user\nchown -R ec2-user:ec2-user /home/ec2-user\necho \"Bootstrap complete!\""
     }
